# Rust build artifacts
/target/
**/*.rs.bk
*.pdb

# cc-memory plugin local state (not part of this project's source)
/memory/

# Render outputs / scratch (we don't version generated images)
/out/
/output/
*.tmp

# AI-denoise sidecar: downloaded model weights (~137 MB) + Python caches.
# The code (python/denoise.py) is versioned; the weights are fetched on first run.
/python/weights/
**/__pycache__/

# Local config that may hold secrets (OpenAI/analysis API keys, model choices).
# Written by the in-app Settings panel; never commit it.
.env
autoshop.local.toml
autoshop.local.json

# OS / editor cruft
Thumbs.db
.DS_Store
desktop.ini
.vscode/
.idea/
.gstack/
